# =============================================================================
#  LUMA STORE — Variables de entorno
#  Copia este archivo como .env y completa los valores para tu entorno.
#  NUNCA subas .env al repositorio (ya está en .gitignore).
# =============================================================================

# ── Seguridad base ─────────────────────────────────────────────────────────────
# Genera una SECRET_KEY segura con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ──────────────────────────────────────────────────────────────
# DESARROLLO: dejar DATABASE_URL vacío → Django usa SQLite automáticamente.
# PRODUCCIÓN: Railway inyecta DATABASE_URL automáticamente al agregar el addon PostgreSQL.
#             No necesitas configurarlo manualmente en Railway.
DATABASE_URL=

# ── Caché ──────────────────────────────────────────────────────────────────────
# DESARROLLO: dejar REDIS_URL vacío → Django usa caché en memoria automáticamente.
# PRODUCCIÓN: Railway inyecta REDIS_URL automáticamente al agregar el addon Redis.
#             Sin Redis, la caché de StoreConfig funciona pero no se comparte entre workers.
REDIS_URL=

# ── CORS (dominios del frontend en producción) ────────────────────────────────
# Separados por coma. En desarrollo no hace falta (localhost ya está incluido).
# Ejemplo producción: https://admin.mitienda.com,https://mitienda.com
CORS_ALLOWED_ORIGINS=

# ── Tienda ─────────────────────────────────────────────────────────────────────
STORE_NAME=Mi Tienda
STORE_WHATSAPP=573001234567
STORE_PRIMARY_COLOR=#2E86C1

# ── Cloudinary (almacenamiento de imágenes en producción) ─────────────────────
# DESARROLLO: dejar vacío → las imágenes se guardan en filesystem local (media/).
# PRODUCCIÓN: crea cuenta gratuita en https://console.cloudinary.com
#             Free tier: 25GB almacenamiento + 25GB/mes de transferencia.
#             Copia el CLOUDINARY_URL de tu dashboard y extrae los valores:
#             cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (notificaciones) ─────────────────────────────────────────────────────
# DESARROLLO: dejar vacío → los emails se imprimen en la consola del servidor.
# PRODUCCIÓN: configura uno de estos proveedores (ambos gratuitos para bajo volumen):
#
#   Opción A — Gmail con App Password (hasta ~500/día, gratis):
#     EMAIL_HOST=smtp.gmail.com
#     EMAIL_PORT=587
#     EMAIL_USE_TLS=True
#     EMAIL_HOST_USER=tucorreo@gmail.com
#     EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx   ← App Password (no tu contraseña normal)
#
#   Opción B — Resend.com (3.000 emails/mes gratis, sin tarjeta de crédito):
#     EMAIL_HOST=smtp.resend.com
#     EMAIL_PORT=465
#     EMAIL_USE_TLS=True
#     EMAIL_HOST_USER=resend
#     EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxx       ← API Key de Resend
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Mi Tienda <noreply@mitienda.com>

# ── Sentry (monitoreo de errores en producción) ───────────────────────────────
# DESARROLLO: dejar vacío → Sentry desactivado, no interfiere con el dev.
# PRODUCCIÓN: pega el DSN de tu proyecto en https://sentry.io
#   1. Crear cuenta gratuita en sentry.io
#   2. Nuevo proyecto → plataforma: Django
#   3. Copiar el DSN que aparece en la configuración
# Free tier: 5.000 errores/mes, ilimitado en organizaciones pequeñas.
SENTRY_DSN=

# ── Pasarela de pagos (esqueleto — desactivado por defecto) ───────────────────
# PAYMENT_ENABLED=False → No se procesa ningún cobro (modo actual).
# Para activar en el futuro:
#   1. Cambiar PAYMENT_ENABLED=True
#   2. Seleccionar proveedor: wompi | bold | stripe
#   3. Completar las claves del proveedor elegido
#
# Wompi (Bancolombia Pay) — Colombia: sin costo fijo, ~2.9% por transacción exitosa
#   PAYMENT_PROVIDER=wompi
#   PAYMENT_PUBLIC_KEY=pub_test_xxxxxxxxxxxx
#   PAYMENT_PRIVATE_KEY=prv_test_xxxxxxxxxxxx
#
# Bold — Colombia: sin costo fijo, ~2.9% por transacción exitosa
#   PAYMENT_PROVIDER=bold
#   PAYMENT_PUBLIC_KEY=xxxxxxxxxxxx
#   PAYMENT_PRIVATE_KEY=xxxxxxxxxxxx
#
PAYMENT_ENABLED=False
PAYMENT_PROVIDER=
PAYMENT_PUBLIC_KEY=
PAYMENT_PRIVATE_KEY=
